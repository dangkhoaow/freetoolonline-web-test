<?xml version="1.0" encoding="UTF-8"?>
<!--
  This file is intentionally empty. The site's sitemap is built per deploy
  by `scripts/sitemap-writer.mjs`, which emits five files into `dist/`:
    - sitemap.xml         (sitemap index)
    - sitemap-tools.xml   (tool routes)
    - sitemap-hubs.xml    (hub routes)
    - sitemap-guides.xml  (guide routes)
    - sitemap-pages.xml   (info / resource routes)

  The route registry is `scripts/site-data.mjs`:
    - JSP_BY_ROUTE   -> every public route shipped by the build
    - GUIDE_ROUTES   -> /guides/* subset (drives sitemap-guides.xml)
    - INFO_ROUTES    -> /, /about-us, /contact-us, /privacy-policy, etc.
    - ALIAS_ROUTES   -> 301 source -> canonical mappings (excluded from sitemap)

  `<lastmod>` per URL is derived from the page's CMS file mtimes
  (`BODYTITLE<slug>.txt`, `BODYHTML<slug>.html`, etc.) so any content edit
  bumps the timestamp without a manual update.

  Adding or removing a route therefore happens in ONE place
  (`scripts/site-data.mjs`); the next `npm run export` regenerates the
  sitemap chain and the visible /sitemap.html index together.

  This stub stays in source as a tombstone so anyone grep-ing for
  `sitemap.xml` lands here and reads the contract. The file is NOT copied
  to dist (see export-site.mjs::copyStaticAssets).
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"></urlset>
